# =============================================================================
# MNESYA - Variables d'environnement (docker-compose)
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=mnesya_user
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=mnesya_db

# --- Backend ---
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# Documentation API (Swagger/ReDoc) — protégé par Basic Auth
DOCS_USERNAME=admin
DOCS_PASSWORD=changeme_docs_password

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme_pgadmin_password
