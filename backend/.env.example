# =============================================================================
# MNESYA Backend - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# =============================================================================

# --- Base de données ---
DATABASE_URL=postgresql://mnesya_user:changeme@localhost:5432/mnesya_db

# --- Sécurité ---
# Générer avec : openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# --- Documentation API (Swagger/ReDoc) ---
DOCS_USERNAME=admin
DOCS_PASSWORD=changeme_docs_password

# --- Tests ---
TEST_DATABASE_URL=postgresql://mnesya_user:changeme@localhost:5432/mnesya_test_db
